<div className="relative w-full max-w-md overflow-hidden rounded-3xl border border-slate-700 bg-slate-900">
  <div className="aspect-[4/5] w-full overflow-hidden">
    {nosotros.foto ? (
      <img
        src={nosotros.foto}
        alt={nosotros.nombre_completo || "Foto profesional"}
        className="h-full w-full object-cover"
      />
    ) : (
      <div className="flex h-full w-full items-center justify-center text-slate-400">
        Sin foto
      </div>
    )}
  </div>

  <div className="absolute bottom-6 left-6 right-6 rounded-2xl border border-slate-700 bg-slate-950/90 p-5 backdrop-blur">
    <h3 className="text-lg font-bold text-white">
      {nosotros.nombre_completo}
    </h3>
    <p className="text-sm text-slate-400">
      {nosotros.cargo}
    </p>

    <div className="mt-3 flex flex-wrap gap-2">
      <span className="rounded-md border border-violet-500/40 bg-violet-500/10 px-3 py-1 text-xs text-violet-300">
        {nosotros.credencial1}
      </span>
      <span className="rounded-md border border-violet-500/40 bg-violet-500/10 px-3 py-1 text-xs text-violet-300">
        {nosotros.credencial2}
      </span>
    </div>
  </div>
</div>
